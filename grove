#!/usr/bin/env bash
#
# grove — git worktree + tmux session orchestrator (a tiny superset.sh replacement)
#
# Each branch gets its own isolated worktree under ./.worktrees/<branch> and its
# own persistent tmux session. Closing your laptop won't kill running agents;
# windows ("tabs") are yours to add inside the session.
#
# Usage:
#   grove create <branch> [from-branch]  New branch + worktree + tmux session.
#                                        from-branch defaults to the current branch
#                                        and becomes the session's diff-pane base.
#   grove attach <branch>                Worktree + session for a branch that already
#                                        exists (or reattach if the session is live).
#   grove list                           In a repo: list its worktrees + session state.
#                                        Outside any repo: a tree of every running
#                                        grove session grouped by repo.
#   grove clean <branch> [-f]            Run teardown, kill session, remove worktree,
#                                        offer to delete the branch.
#   grove base [<branch>]                Show or set the base branch for the current
#                                        session — drives the right-side diff pane.
#   grove reset [<branch>]               Kill the right-side diff pane and respawn it.
#                                        With no arg: current session. With a branch:
#                                        the session for that worktree. Custom panes
#                                        you added are left alone.
#   grove init                           Scaffold setup.sh + teardown.sh hooks for this repo.
#   grove migrate <branch> [-f]          Move <branch>'s existing worktree into
#                                        .worktrees/<branch> via git worktree move.
#                                        -f passes --force through (allows dirty trees,
#                                        skips lock check).
#   grove migrate <branch> --adopt       Don't move — register the existing path with
#                                        grove and (re)launch the tmux session there.
#   grove migrate --all [-f]             Sweep every out-of-place worktree in this repo.
#   grove help
#
# Every session opens with a small right-hand pane showing the changed files vs <base>
# as a tree (refreshed every 2s). Change the base with `grove base <branch>`.
#
# Per-repo hooks (replace your old setup script):
#   $GROVE_HOME/<repo-name>/setup.sh      runs on create/attach, inside the new worktree
#   $GROVE_HOME/<repo-name>/teardown.sh   runs on clean, inside the worktree before removal
#   (default GROVE_HOME=~/.grove)
#   Both run with CWD = the worktree and these vars:
#     GROVE_WORKTREE  GROVE_BRANCH  GROVE_FROM  GROVE_REPO_ROOT  GROVE_REPO_NAME
#
set -euo pipefail

# Resolve symlinks so $GROVE_BIN points at the real script next to lib/, even
# when invoked through a symlink in ~/.local/bin.
_grove_resolve_self() {
  local src="${BASH_SOURCE[0]}" dir
  while [ -L "$src" ]; do
    dir="$(cd "$(dirname "$src")" && pwd -P)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  printf '%s' "$(cd "$(dirname "$src")" && pwd -P)/$(basename "$src")"
}

GROVE_BIN="$(_grove_resolve_self)"
GROVE_LIB="$(dirname "$GROVE_BIN")/lib"
GROVE_HOME="${GROVE_HOME:-$HOME/.grove}"

# shellcheck source=lib/util.sh
source "$GROVE_LIB/util.sh"
# shellcheck source=lib/session.sh
source "$GROVE_LIB/session.sh"
# shellcheck source=lib/panes.sh
source "$GROVE_LIB/panes.sh"
for _cmd_file in "$GROVE_LIB/commands/"*.sh; do
  # shellcheck source=/dev/null
  source "$_cmd_file"
done
unset _cmd_file

usage() {
  awk 'NR==1 && /^#!/ {next} /^#/ {sub(/^# ?/, ""); print; next} {exit}' "$GROVE_BIN"
}

main() {
  local cmd="${1:-help}"
  case "$cmd" in
    create|new)     shift; cmd_create "$@" ;;
    attach|open)    shift; cmd_attach "$@" ;;
    list|ls)        shift; cmd_list "$@" ;;
    clean|rm)       shift; cmd_clean "$@" ;;
    base)           shift; cmd_base "$@" ;;
    reset)          shift; cmd_reset "$@" ;;
    init)           shift; cmd_init "$@" ;;
    migrate|mv)     shift; cmd_migrate "$@" ;;
    _pane)          shift; _cmd_pane "$@" ;;
    _pin)           shift; _cmd_pin "$@" ;;
    _setup)         shift; _cmd_setup "$@" ;;
    help|-h|--help) usage ;;
    *)              die "unknown command '$cmd' — try: grove help" ;;
  esac
}

main "$@"
